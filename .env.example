# Bitget API (демо-ключи с bitget.com/ru/account/newapi)
BITGET_API_KEY=your_api_key_here
BITGET_SECRET_KEY=your_secret_key_here
BITGET_PASSPHRASE=your_passphrase_here

# Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# News API (optional, for fundamental analysis)
NEWS_API_KEY=your_newsapi_key_here

# Trading mode: demo | paper | live
# demo = демо-счёт Bitget, виртуальные деньги, реальные ордера на демо-бирже
# paper = только анализ, ордера НЕ отправляются
# live = реальные деньги (ОСТОРОЖНО!)
TRADING_MODE=demo

# Виртуальный баланс для paper mode (в USDT)
PAPER_BALANCE=10000

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
